# ====================================
# Base de Datos
# ====================================
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/ticket_db

# ====================================
# JWT - Autenticación
# ====================================
# Generá un string aleatorio de al menos 32 caracteres
JWT_SECRET=tu_secreto_super_seguro_minimo_32_caracteres
JWT_REFRESH_SECRET=tu_secreto_refresh_super_seguro_minimo_32_caracteres

# ====================================
# Servidor
# ====================================
PORT=3000
NODE_ENV=development

# ====================================
# CORS (Opcional)
# ====================================
# CORS_ORIGIN=http://localhost:3000,https://tudominio.com

# ====================================
# Producción
# ====================================
# DATABASE_URL_PROD=postgresql://usuario:contraseña@prod-host:5432/ticket_db_prod
